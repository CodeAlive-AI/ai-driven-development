#!/bin/bash
set -euo pipefail
LOG="${CONSILIUM_FAKE_ARGV_LOG:-/dev/null}"
python3 -c '
import json,sys
print(json.dumps({"bin":"claude","argv":sys.argv[1:],"stdin":sys.stdin.read()}))
' -- "$@" >> "$LOG"

if printf '%s\n' "$@" | grep -q -- 'stream-json'; then
  echo '{"type":"content_block_delta","delta":{"type":"text_delta","text":"FAKE_CLAUDE_OK"}}'
  echo '{"type":"result","result":"FAKE_CLAUDE_OK"}'
else
  echo 'FAKE_CLAUDE_OK'
fi
exit 0
