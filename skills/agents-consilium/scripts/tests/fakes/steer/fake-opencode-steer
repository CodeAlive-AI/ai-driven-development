#!/usr/bin/env python3
"""Steerable OpenCode fake: ephemeral HTTP serve + SSE + prompt_async + abort."""
from __future__ import annotations

import json
import os
import sys
import threading
import time
import uuid
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from typing import Any, Dict, List, Optional
from urllib.parse import urlparse, parse_qs


class State:
    def __init__(self):
        self.session_id = "sess_" + uuid.uuid4().hex[:8]
        self.prompts: List[Dict[str, Any]] = []
        self.aborted = False
        self.done = False
        self.lock = threading.Lock()
        self.sse_queues: List[List[str]] = []
        self.slow = float(os.environ.get("CONSILIUM_FAKE_STEER_SLOW", "0.35"))


STATE = State()


def broadcast(event: Dict[str, Any]) -> None:
    data = f"data: {json.dumps(event, ensure_ascii=False)}\n\n"
    with STATE.lock:
        for q in STATE.sse_queues:
            q.append(data)


def _expected_auth() -> Optional[str]:
    """Return expected Basic token, or None if auth is disabled (tests only)."""
    password = os.environ.get("OPENCODE_SERVER_PASSWORD") or ""
    if not password:
        return None
    username = os.environ.get("OPENCODE_SERVER_USERNAME") or "opencode"
    import base64

    return "Basic " + base64.b64encode(f"{username}:{password}".encode("utf-8")).decode("ascii")


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        return

    def _check_auth(self) -> bool:
        expected = _expected_auth()
        if expected is None:
            return True
        got = self.headers.get("Authorization") or ""
        if got == expected:
            return True
        self.send_response(401)
        self.send_header("WWW-Authenticate", 'Basic realm="Secure Area"')
        self.send_header("Content-Length", "0")
        self.end_headers()
        return False

    def _json(self, code: int, obj: Any) -> None:
        body = json.dumps(obj).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _empty(self, code: int = 204) -> None:
        self.send_response(code)
        self.end_headers()

    def do_GET(self):
        if not self._check_auth():
            return
        path = urlparse(self.path).path
        if path == "/global/health":
            self._json(200, {"healthy": True})
            return
        if path in ("/global/event", "/event"):
            self.send_response(200)
            self.send_header("Content-Type", "text/event-stream")
            self.send_header("Cache-Control", "no-cache")
            self.send_header("Connection", "keep-alive")
            self.end_headers()
            q: List[str] = []
            with STATE.lock:
                STATE.sse_queues.append(q)
            try:
                # Keep open until done
                while not STATE.done:
                    with STATE.lock:
                        items = list(q)
                        q.clear()
                    for item in items:
                        self.wfile.write(item.encode("utf-8"))
                        self.wfile.flush()
                    time.sleep(0.05)
                # flush remaining
                with STATE.lock:
                    items = list(q)
                for item in items:
                    self.wfile.write(item.encode("utf-8"))
                    self.wfile.flush()
            except BrokenPipeError:
                pass
            return
        self._json(404, {"error": "not found", "path": path})

    def do_POST(self):
        if not self._check_auth():
            return
        parsed = urlparse(self.path)
        path = parsed.path
        length = int(self.headers.get("Content-Length") or 0)
        raw = self.rfile.read(length) if length else b""
        body: Dict[str, Any] = {}
        if raw:
            try:
                body = json.loads(raw.decode("utf-8"))
            except json.JSONDecodeError:
                body = {}

        if path == "/session" or path.startswith("/session?"):
            self._json(
                200,
                {"id": STATE.session_id, "title": "fake", "directory": body.get("directory") or ""},
            )
            return

        if path.startswith("/session/") and path.endswith("/prompt_async"):
            parts = body.get("parts") or []
            text = ""
            for p in parts:
                if isinstance(p, dict) and p.get("type") == "text":
                    text += p.get("text") or ""
            client = (body.get("metadata") or {}).get("clientId") or ""
            with STATE.lock:
                STATE.prompts.append({"text": text, "clientId": client, "t": time.time()})
            # Emit delta after short delay in background
            def work(prompt_index: int):
                time.sleep(STATE.slow * 0.4)
                chunk = "FAKE_OC"
                if client and client != "initial":
                    chunk += f"+{client[:6]}"
                broadcast(
                    {
                        "type": "message.part.delta",
                        "properties": {
                            "sessionID": STATE.session_id,
                            "delta": chunk,
                            "part": {"type": "text", "text": chunk, "sessionID": STATE.session_id},
                        },
                    }
                )
                time.sleep(STATE.slow * 0.3)
                # Idle when this is still the latest prompt (step boundary)
                with STATE.lock:
                    latest = len(STATE.prompts)
                if prompt_index == latest:
                    broadcast(
                        {
                            "type": "session.idle",
                            "properties": {"sessionID": STATE.session_id, "status": "idle"},
                        }
                    )
                    # Allow a short window for more steers, then finish process
                    def finish(expected: int):
                        time.sleep(0.55)
                        with STATE.lock:
                            if len(STATE.prompts) == expected:
                                STATE.done = True

                    threading.Thread(target=finish, args=(latest,), daemon=True).start()

            with STATE.lock:
                idx = len(STATE.prompts)
            threading.Thread(target=work, args=(idx,), daemon=True).start()
            self._empty(204)
            return

        if path.startswith("/session/") and path.endswith("/abort"):
            with STATE.lock:
                STATE.aborted = True
            broadcast(
                {
                    "type": "session.status",
                    "properties": {"sessionID": STATE.session_id, "status": "aborted"},
                }
            )
            self._empty(204)
            return

        self._json(404, {"error": "not found", "path": path})


def main() -> int:
    log = os.environ.get("CONSILIUM_FAKE_ARGV_LOG")
    if log:
        with open(log, "a", encoding="utf-8") as f:
            f.write(json.dumps({"bin": "opencode-steer", "argv": sys.argv[1:]}) + "\n")

    # Parse --port 0 / --hostname
    host = "127.0.0.1"
    port = 0
    args = sys.argv[1:]
    for i, a in enumerate(args):
        if a == "--hostname" and i + 1 < len(args):
            host = args[i + 1]
        if a == "--port" and i + 1 < len(args):
            port = int(args[i + 1])

    # Threading server so SSE clients do not block prompt_async / abort.
    httpd = ThreadingHTTPServer((host, port), Handler)
    real_port = httpd.server_address[1]
    # Match real opencode log line
    print(f"opencode server listening on http://{host}:{real_port}", flush=True)
    # Also stderr as some adapters read stderr
    print(f"opencode server listening on http://{host}:{real_port}", file=sys.stderr, flush=True)

    t = threading.Thread(target=httpd.serve_forever, daemon=True)
    t.start()
    # Run until STATE.done or hard deadline (always terminate)
    deadline = time.time() + 12
    while time.time() < deadline and not STATE.done:
        time.sleep(0.1)
    with STATE.lock:
        STATE.done = True
    try:
        httpd.shutdown()
    except Exception:
        pass
    try:
        httpd.server_close()
    except Exception:
        pass
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
